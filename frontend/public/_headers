# Headers de sécurité pour Netlify/Vercel
# Basé sur l'audit PageSpeed - Phase 4

/*
  # Sécurité HTTPS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Protection contre le clickjacking
  X-Frame-Options: SAMEORIGIN
  
  # Protection XSS
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  
  # Politique de référent
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  
  # Cross-Origin
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin
  
  # Content Security Policy (à ajuster selon vos besoins)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.clarity.ms https://assets.calendly.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://www.clarity.ms https://us.i.posthog.com; frame-src 'self' https://calendly.com; object-src 'none'; base-uri 'self'; form-action 'self'

# Cache pour les assets statiques
/static/*
  Cache-Control: public, max-age=31536000, immutable

# Cache pour les images
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable

# Cache pour les fonts
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Pas de cache pour le HTML
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Service Worker
/service-worker.js
  Cache-Control: public, max-age=0, must-revalidate

# Manifest
/manifest.json
  Cache-Control: public, max-age=86400
